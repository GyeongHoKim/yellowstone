{
  "compilerOptions": {
    "target": "ES2020",
    "rootDir": "lib",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2020"],
    "types": ["node", "sdp-transform"],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "lib/**/*"
  ]
}